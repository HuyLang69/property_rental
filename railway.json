{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "providers": ["php", "node"],
      "setup": {
        "nixPkgs": ["php82", "nodejs_20"]
      }
    }
  },
  "deploy": {
    "startCommand": "php artisan storage:link && php artisan serve --host=0.0.0.0 --port=$PORT",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  },
  "variables": {
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "APP_URL": "https://${RAILWAY_PUBLIC_DOMAIN}",
    "DB_CONNECTION": "mysql",
    "SESSION_DRIVER": "cookie",
    "CACHE_STORE": "array",
    "QUEUE_CONNECTION": "sync",
    "MIGRATION_TOKEN": "change-this-to-something-secret-123"
  }
}
