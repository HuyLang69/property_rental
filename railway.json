{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "php artisan storage:link && php artisan serve --host=0.0.0.0 --port=$PORT",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300
  },
  "variables": {
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "DB_CONNECTION": "mysql"
  }
}
