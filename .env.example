# Railway / Production Settings
PORT=8000
APP_NAME=NestAway
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=sqlite
DB_DATABASE=/app/database/property_db.sqlite

SESSION_DRIVER=file
FILESYSTEM_DISK=public
CACHE_STORE=file

# Admin User Setup
ADMIN_EMAIL=admin@nestaway.com
ADMIN_PASSWORD=password123

# Standard Laravel Example Vars
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
BCRYPT_ROUNDS=12
MAIL_MAILER=log
